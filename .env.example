# Supabase PostgreSQL - pooled connection (for app runtime)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase PostgreSQL - direct connection (for migrations)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Google OAuth (restrict to .edu in callback)
GOOGLE_CLIENT_ID="replace-me"
GOOGLE_CLIENT_SECRET="replace-me"

# Admin
ADMIN_EMAILS="admin@university.edu"

# Stripe (optional - set ENABLE_CREDIT_PURCHASES=true to activate)
ENABLE_CREDIT_PURCHASES="false"
STRIPE_SECRET_KEY="sk_test_replace"
STRIPE_WEBHOOK_SECRET="whsec_replace"
STRIPE_PRICE_10="price_10_credits"
STRIPE_PRICE_25="price_25_credits"
STRIPE_PRICE_50="price_50_credits"

# Logo rendering (optional, for landing-page marquee logos via Logo.dev)
NEXT_PUBLIC_LOGO_DEV_TOKEN="pk_test_replace"

# Email verification tuning (optional)
EMAIL_VERIFICATION_PROVIDER="abstract"
ABSTRACT_API_KEY="replace-with-abstract-api-key"
ABSTRACT_API_KEYS="replace-with-primary-and-secondary-keys-comma-separated"
ABSTRACT_API_KEY_SECONDARY="replace-with-secondary-key"
ABSTRACT_API_BASE_URL="https://emailreputation.abstractapi.com/v1/"
ABSTRACT_TIMEOUT_MS="5000"
ABSTRACT_MIN_INTERVAL_MS="1000"
ABSTRACT_MIN_QUALITY_SCORE="0.7"
SMTP_MIN_INTERVAL_MS="5000"
SMTP_CONNECT_TIMEOUT_MS="4500"
SMTP_MAX_MX_HOSTS="3"
EMAIL_DNS_CACHE_TTL_MS="600000"
EMAIL_DNS_NEGATIVE_CACHE_TTL_MS="120000"
